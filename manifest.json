{
  "manifest_version": 3,
  "name": "Chemistry Notes Helper",
  "version": "1.0",
  "description": "alt number to subscript",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ]
}
